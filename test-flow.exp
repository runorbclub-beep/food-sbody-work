#!/usr/bin/expect -f
set timeout 30
set server "129.212.236.200"
set password "ZH@19880401n"

spawn ssh -o StrictHostKeyChecking=no root@$server
expect "password:"
send "$password\r"
expect "#"

# Clean test data
send "rm -f /root/fridge-api/fridge.db && echo 'DB cleaned'\r"
expect "#"
send "pm2 restart fridge-api 2>&1 | tail -3\r"
expect "#"
send "sleep 2\r"
expect "#"

# Register first user
send "curl -s http://localhost:3002/api/register -X POST -H 'Content-Type: application/json' -d '{\"name\":\"爸爸\",\"password\":\"test1234\",\"familyName\":\"我们一家\"}' 2>&1\r"
expect "#"

# Get token & invite code
send "TOKEN=\$(curl -s http://localhost:3002/api/login -X POST -H 'Content-Type: application/json' -d '{\"name\":\"爸爸\",\"password\":\"test1234\"}' | python3 -c \"import sys,json;print(json.load(sys.stdin)['token'])\" 2>/dev/null)\r"
expect "#"
send "CODE=\$(curl -s http://localhost:3002/api/family/invite -H \"Authorization: Bearer \$TOKEN\" | python3 -c \"import sys,json;print(json.load(sys.stdin)['code'])\" 2>/dev/null)\r"
expect "#"
send "echo \"Invite code: \$CODE\"\r"
expect "#"

# Second user joins
send "curl -s http://localhost:3002/api/family/join -X POST -H 'Content-Type: application/json' -d '{\"name\":\"妈妈\",\"password\":\"test1234\",\"avatar\":\"👩\",\"inviteCode\":\"'\"\$CODE\"'\"}' 2>&1\r"
expect "#"

# 爸爸 adds milk
send "curl -s http://localhost:3002/api/inventory -X POST -H 'Content-Type: application/json' -H \"Authorization: Bearer \$TOKEN\" -d '{\"productName\":\"牛奶\",\"emoji\":\"🥛\",\"quantity\":3,\"unit\":\"盒\",\"location\":\"door-1\"}' 2>&1\r"
expect "#"

# Mommy's token checks inventory
send "MTOKEN=\$(curl -s http://localhost:3002/api/login -X POST -H 'Content-Type: application/json' -d '{\"name\":\"妈妈\",\"password\":\"test1234\"}' | python3 -c \"import sys,json;print(json.load(sys.stdin)['token'])\" 2>/dev/null)\r"
expect "#"
send "curl -s http://localhost:3002/api/inventory -H \"Authorization: Bearer \$MTOKEN\" | python3 -c \"import sys,json;d=json.load(sys.stdin);[print(f'  {i[chr(101)+chr(109)+chr(111)+chr(106)iers]} {i[chr(112)+chr(114)+chr(111)+chr(100)+chr(117)+chr(99)+chr(116)+chr(95)+chr(110)+chr(97)+chr(109)+chr(101)]} x{i[chr(113)+chr(117)+chr(97)+chr(110)+chr(116)+chr(105)+chr(116)+chr(121)]}{i[chr(117)+chr(110)+chr(105)+chr(116)]} (by {i[chr(97)+chr(100)+chr(100)+chr(101)+chr(100)+chr(95)+chr(98)+chr(121)+chr(95)+chr(110)+chr(97)+chr(109)+chr(101)]})') for i in d]\" 2>&1\r"
expect "#"

send "exit\r"
expect eof
