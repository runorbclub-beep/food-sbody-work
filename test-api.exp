send "echo '---SEPARATOR---'\r"
expect "#"

# Test local nginx
send "curl -s http://localhost/api/register -X POST -H 'Content-Type: application/json' -d '{\"name\":\"妈妈\",\"password\":\"test1234\",\"avatar\":\"👩\",\"familyName\":\"outro\"}' 2>&1 | head -c 300\r"
